#. Author of the plugin
#: disable-blog.php
msgid "Joshua David Nelson"
msgstr "Joshua David Nelson"

#. translators: This text appears in the Customizer > Homepage Settings and
#. provides the context for the homepage select field there.
#: includes/class-disable-blog-admin.php:1383
msgid "You can choose what's displayed on the homepage of your site. To set a static homepage, create or select the page below."
msgstr "Puedes elegir lo que se muestra en la página de inicio de tu sitio. Para establecer una página de inicio estática, crea o selecciona la página que aparece a continuación."

#: includes/class-disable-blog-admin.php:81
msgid "GitHub"
msgstr "GitHub"

#: includes/class-disable-blog-admin.php:80
msgid "Donate"
msgstr "Donar"

#: includes/class-disable-blog-admin.php:79
msgid "Review"
msgstr "Valoración"

#: includes/class-disable-blog-admin.php:78
msgid "Support"
msgstr "Soporte"

#. translators: this notice informs the user why the blog page editor is
#. disabled and that it is redirected to the homepage.
#: includes/class-disable-blog-admin.php:1411
msgid "You are currently editing the page that shows your latest posts, which is redirected to the homepage because the blog is disabled."
msgstr "Actualmente está editando la página que muestra sus últimas entradas, que se redirige a la página de inicio porque el blog está desactivado."

#. translators: %1$s: Number of pieces of content by this author. %2$s and %3$s
#. are the singular and plural names, respectively, for the content type. For
#. example: "1 page by this author" and "2 pages by this author".
#: includes/class-disable-blog-admin.php:1287
msgid "%1$s %2$s by this author"
msgid_plural "%1$s %3$s by this author"
msgstr[0] "%1$s %2$s por este autor"
msgstr[1] "%1$s %3$s por este autor"

#. translators: %s: The name of the query parameter being tested.
#: includes/class-disable-blog-admin.php:1135
msgid "The REST API did not process the %s query parameter correctly."
msgstr "La API REST no procesó el parámetro de consulta%s correctamente."

#: includes/class-disable-blog-admin.php:1129
msgid "The REST API did not behave correctly"
msgstr "La API REST no se comportó correctamente"

#. translators: 1: The HTTP error code. 2: The HTTP error message.
#: includes/class-disable-blog-admin.php:1118
msgid "The REST API call gave the following unexpected result: (%1$d) %2$s."
msgstr "La llamada a la API REST dio el siguiente resultado inesperado: (%1$d)%2$s."

#: includes/class-disable-blog-admin.php:1112
msgid "The REST API encountered an unexpected result"
msgstr "La API REST encontró un resultado inesperado"

#. translators: 1: The WordPress error message. 2: The WordPress error code.
#: includes/class-disable-blog-admin.php:1103
msgid "Error: %1$s (%2$s)"
msgstr "Error: %1$s (%2$s)"

#: includes/class-disable-blog-admin.php:1100
msgid "The REST API request failed due to an error."
msgstr "La solicitud de API REST falló debido a un error."

#: includes/class-disable-blog-admin.php:1094
msgid "The REST API encountered an error"
msgstr "La API REST encontró un error"

#: includes/class-disable-blog-admin.php:1050
msgid "Performance"
msgstr "Rendimiento"

#: includes/class-disable-blog-admin.php:1047
msgid "The REST API is available"
msgstr "La API REST está disponible"

#. translators: This string is used to indicate that the blog page is
#. redirected to the homepage.
#: includes/class-disable-blog-admin.php:1010
msgid "Redirected to the homepage"
msgstr "Redirigido a la página de inicio"

#. Description of the plugin
#: disable-blog.php
msgid "Go blog-less with WordPress. This plugin disables all blog-related functionality (by hiding, removing, and redirecting)."
msgstr "WordPress sin blog. Este plugin desactiva toda la funcionalidad relacionada con los blogs (ocultando, eliminando y redireccionando)."

#. translators: Prompt to configure the site for static homepage and posts
#. page.
#: includes/class-disable-blog-admin.php:678
msgid "Disable Blog is not fully active until a static page is selected for the site's homepage."
msgstr "Desactivar Blog no está totalmente activo hasta que se selecciona una página estática para la página de inicio del sitio."

#. translators: Direct the user to the Reading Settings admin page.
#: includes/class-disable-blog-admin.php:673
msgid "Change in <a href=\"%s\">Reading Settings</a>."
msgstr "Cambio en los <a href=\"%s\">ajustes de lectura</a>."

#. Author URI of the plugin
#: disable-blog.php
msgid "http://joshuadnelson.com"
msgstr "http://joshuadnelson.com"

#. Plugin URI of the plugin
#: disable-blog.php
msgid "https://wordpress.org/plugins/disable-blog/"
msgstr "https://es.wordpress.org/plugins/disable-blog/"

#. translators: This error shows up if the user does not have permissions to
#. uninstall the plugin.
#: uninstall.php:70
msgid "You do not have permission to run this script."
msgstr "No tienes permisos para ejecutar este script."

#. translators: This error shows up when the uninstall process is run but the
#. user login session is invalid.
#: uninstall.php:57
msgid "You must be logged in to run this script."
msgstr "Debes acceder para ejecutar este script."

#. Plugin Name of the plugin
#. translators: The plugin name.
#: disable-blog.php uninstall.php:60 uninstall.php:73
msgid "Disable Blog"
msgstr "Desactivar blog"